{
  "name": "impress-pedidos",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "set HTTP_PROXY=& set HTTPS_PROXY=& set ALL_PROXY=& set NODE_OPTIONS=--use-system-ca&& next dev --webpack",
    "build": "set HTTP_PROXY=& set HTTPS_PROXY=& set ALL_PROXY=& set NODE_OPTIONS=--use-system-ca&& next build --webpack",
    "start": "next start",
    "print-app": "electron ./local-app",
    "pack-print-app": "electron-packager ./local-app \"IMPRESS Print\" --platform=win32 --arch=x64 --out=dist --overwrite",
    "install-print-app": "powershell -ExecutionPolicy Bypass -File .\\local-app\\install-impress-print.ps1",
    "lint": "next lint"
  },
  "dependencies": {
    "@react-pdf/renderer": "^4.3.0",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.104.1",
    "googleapis": "^171.4.0",
    "next": "16.2.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-pdf": "^10.4.1"
  },
  "devDependencies": {
    "@electron/packager": "^20.0.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "electron": "^42.0.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
